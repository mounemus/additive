generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Connexion directe (non poolée) pour les migrations / db push sur Neon.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Product {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  shortDescription String?
  description      String?
  price            Float?
  currency         String         @default("CAD")
  collectionId     String?
  collection       Collection?    @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  colors           String[]
  materials        String[]
  dimensions       String?
  features         String[]
  model3dUrl       String?        // modèle 3D GLB/GLTF (visualisable et manipulable)
  customizable     Boolean        @default(true)
  isFeatured       Boolean        @default(false)
  isPublished      Boolean        @default(false)
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Collection {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  description    String?
  tagline        String?
  image          String?
  video          String?
  products       Product[]
  order          Int       @default(0)
  isPublished    Boolean   @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String?
  message   String
  status    String   @default("new")
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

// Demande issue du configurateur "Créer mes lunettes".
// Reprend les principes du plugin WordPress : profil de style en tags,
// concept choisi parmi 3 propositions max, prix recalculé serveur,
// + analyse morphologique, mesures mm, moodboard et photo temporaire.
model CustomizationRequest {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String?
  faceShape      String?
  measurements   Json?     // mesures mm (PD, largeur visage, pont nasal…)
  analysisReport Json?     // rapport + recommandations de chausse
  styleTags      String[]
  boldness       String?
  conceptLabel   String?
  conceptSummary String?
  conceptData    Json?     // concept choisi complet (notes, scores…)
  matchRate      Int?      // taux de correspondance du concept (0–100)
  moodboardUrl   String?
  options        Json?     // matériau, finition, verres, livraison, urgence
  estimatedPrice Float?
  currency       String   @default("CAD")
  photoToken     String?   // référence vers la photo temporaire (TempPhoto)
  message        String?
  status         String   @default("new")
  note           String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

// Photo temporaire (capture/essayage/portrait) — confidentialité d'abord :
// purgée automatiquement après expiration, supprimable à la demande via token.
model TempPhoto {
  id        String   @id @default(cuid())
  token     String   @unique
  dataUrl   String   // image encodée (data URL) — jamais d'identité analysée
  kind      String   @default("capture") // capture | snapshot | portrait
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  kind      String   @default("image")
  createdAt DateTime @default(now())
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  password    String
  role        String   @default("admin")
  // 2FA TOTP (RFC 6238). Secret scellé via lib/secret-box (AES-256-GCM).
  totpSecret  String?
  totpEnabled Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// Journal d'audit des actions admin (mutations back-office).
// Fire-and-forget : ne bloque jamais la mutation d'origine.
model AuditLog {
  id        String   @id @default(cuid())
  userEmail String
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Fenêtres de rate-limit (clé = scope:identifiant:fenêtre). Nettoyage
// opportuniste des fenêtres expirées à l'écriture — pas de cron requis.
model RateLimitWindow {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@index([resetAt])
}

// Cache des images générées par IA : même profil + même tâche = même image
// réutilisée (TTL) au lieu d'une régénération payante. `url` = URL Vercel Blob
// si le store est configuré, sinon data URL (bornée).
model GeneratedImage {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  task      String
  provider  String?
  url       String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// Journal des appels aux fournisseurs d'images : pilotage des coûts et du
// taux d'échec depuis l'admin (aucun contenu client stocké ici).
model AiCallLog {
  id        String   @id @default(cuid())
  task      String
  provider  String
  model     String?
  ok        Boolean
  cached    Boolean  @default(false)
  latencyMs Int
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
