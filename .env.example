# ── Base de données PostgreSQL ─────────────────────────────────────────────
# Compatible Neon, Supabase, Vercel Postgres ou Postgres local.
# Exemple Neon : postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/additive?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/additive"

# ── Auth.js / NextAuth (espace admin) ──────────────────────────────────────
# Générer un secret : openssl rand -base64 32
NEXTAUTH_SECRET="changez-moi-en-production"
NEXTAUTH_URL="http://localhost:3000"

# ── Compte admin créé par le seed ──────────────────────────────────────────
ADMIN_EMAIL="admin@additive.ca"
ADMIN_PASSWORD="additive2026"

# ── Médias (optionnel — Cloudinary) ────────────────────────────────────────
# Si renseigné, l'uploader admin propose l'upload direct (unsigned preset).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# ── URL publique du site (SEO / sitemap) ───────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
